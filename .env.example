METRICS_PORT=<set this in .env>
SCRAPE_INTERVAL_SECONDS=<set this in .env>
LOG_LEVEL=<set this in .env>
DISCORD_WEBHOOK_URL=<set this in .env>

# eBay Browse API (free OAuth at https://developer.ebay.com/)
# Required to fetch live market pricing — without these, scraper falls back
# to (Cloudflare-blocked) BrickEconomy/BrickLink and then to estimated prices.
EBAY_APP_ID=<your eBay app client id>
EBAY_CERT_ID=<your eBay app client secret>
